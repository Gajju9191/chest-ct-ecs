pipeline {
    agent any
    
    environment {
        ECR_REPOSITORY = credentials('ECR_REPOSITORY')
        AWS_ACCOUNT_ID = credentials('AWS_ACCOUNT_ID')
        AWS_ACCESS_KEY_ID = credentials('AWS_ACCESS_KEY_ID')
        AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_ACCESS_KEY')
        AWS_REGION = 'us-east-1'
        ECS_CLUSTER = 'chest-ct-cluster'
        ECS_SERVICE = 'chest-ct-service'
        MODEL_BUCKET = 'chest-ct-models-155407238003'
        VENV_PATH = '/var/lib/jenkins/workspace/ecs-cicd-d/venv'
    }
    
    triggers {
        cron('0 2 * * *')
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code checked out"
            }
        }
        
        // STEP 1: Retrain model using DVC
        stage('Retrain Model') {
            steps {
                script {
                    echo "🔄 Starting model retraining with DVC..."
                    sh '''
                        # Activate virtual environment and run DVC
                        . /var/lib/jenkins/workspace/ecs-cicd-d/venv/bin/activate
                        dvc repro
                        deactivate
                    '''
                    echo "✅ Model retrained successfully"
                }
            }
        }
        
        // STEP 2: Upload new model to S3
        stage('Upload Model to S3') {
            steps {
                sh "aws s3 cp artifacts/training/model.h5 s3://${MODEL_BUCKET}/model.h5"
                echo "✅ New model uploaded to S3"
            }
        }
        
        // STEP 3: Download model from S3 (for Docker build)
        stage('Download Model from S3') {
            steps {
                sh "aws s3 cp s3://${MODEL_BUCKET}/model.h5 model.h5"
                echo "✅ Model downloaded from S3"
            }
        }
        
        // STEP 4: Login to ECR
        stage('Login to ECR') {
            steps {
                sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                echo "✅ Logged in to ECR"
            }
        }

        // STEP 5: Build Docker image
        stage('Build Image') {
            steps {
                sh "docker build -t ${ECR_REPOSITORY}:latest ."
                echo "✅ Docker image built with new model"
            }
        }

        // STEP 6: Push image to ECR
        stage('Push Image') {
            steps {
                sh "docker push ${ECR_REPOSITORY}:latest"
                echo "✅ Docker image pushed to ECR"
            }
        }

        // STEP 7: Deploy to ECS
        stage('Deploy to ECS') {
            steps {
                sh """
                    aws ecs update-service --cluster ${ECS_CLUSTER} --service ${ECS_SERVICE} --force-new-deployment --region ${AWS_REGION}
                    aws ecs wait services-stable --cluster ${ECS_CLUSTER} --services ${ECS_SERVICE} --region ${AWS_REGION}
                """
                echo "✅ ECS service updated with new model"
            }
        }
        
        // STEP 8: Health Check
        stage('Health Check') {
            steps {
                sh """
                    sleep 10
                    curl -f http://\$(cd terraform && terraform output -raw load_balancer_dns 2>/dev/null || echo 'pending')/health || echo 'Health check pending'
                """
                echo "✅ Health check completed"
            }
        }
    }

    post {
        success {
            echo """
            ========================================
            🎉 RETRAINING & DEPLOYMENT SUCCESSFUL! 🎉
            ========================================
            Model retrained, uploaded to S3, and deployed to ECS!
            ECS Cluster: ${ECS_CLUSTER}
            ECS Service: ${ECS_SERVICE}
            ========================================
            """
        }
        failure {
            echo """
            ========================================
            ❌ RETRAINING/DEPLOYMENT FAILED! ❌
            ========================================
            Check Jenkins console for details.
            ========================================
            """
        }
        always {
            sh 'docker system prune -f'
        }
    }
}